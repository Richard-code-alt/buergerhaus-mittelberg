---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import kontakt from '../data/kontakt.json';
import { getCollection } from 'astro:content';

const title = 'Anfragen — Termin & Veranstaltung | Bürgerhaus Mittelberg';
const description = 'Schreiben Sie uns Ihre Wünsche — Hochzeit, Tagung, Geburtstag, Catering. Wir antworten innerhalb von 48 Stunden.';

const tel = kontakt.telefon.replace(/\s/g, '').replace(/^0/, '');
const anlaesse = (await getCollection('anlaesse')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Anfrage', url: '/anfragen' }]} />
  </Fragment>

  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">Anfrage</span>
      <h1>Anfrage stellen</h1>
      <p class="lead mx-auto">
        Schreiben Sie uns, was Sie feiern möchten — Hochzeit, Tagung, Geburtstag oder etwas anderes.
        Wir melden uns innerhalb von 48 Stunden mit einem konkreten Vorschlag.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="contact-info">
        <p>
          Lieber direkt anrufen?
          <a href={`tel:+49${tel}`}><strong>{kontakt.telefon}</strong></a>
          oder per Mail an
          <a href={`mailto:${kontakt.email}`}><strong>{kontakt.email}</strong></a>.
        </p>
      </div>

      <!-- Netlify Forms — automatisch erkannt, Mail an info@buergerhaus-mittelberg.de -->
      <form
        name="anfrage"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="form"
        id="anfrage-form"
      >
        <input type="hidden" name="form-name" value="anfrage" />
        <p class="hp"><label>Bitte leer lassen: <input name="bot-field" /></label></p>

        <div class="form__error" id="form-error" hidden>
          <strong>Es ist ein Fehler aufgetreten.</strong>
          Bitte versucht es nochmal oder ruft uns direkt an.
        </div>

        <fieldset class="form__group">
          <legend class="form__legend">Was wollen Sie feiern?</legend>
          <div class="form__radio-grid">
            {anlaesse.map((a) => (
              <label class="form__radio-card">
                <input type="radio" name="anlass" value={a.data.titel} required />
                <span class="form__radio-card__title">{a.data.titel}</span>
                <span class="form__radio-card__sub">{a.data.kurz}</span>
              </label>
            ))}
            <label class="form__radio-card">
              <input type="radio" name="anlass" value="Sonstiges" required />
              <span class="form__radio-card__title">Etwas anderes</span>
              <span class="form__radio-card__sub">Konzert, Vereinsfest, Spezielles — schreibt's unten</span>
            </label>
          </div>
        </fieldset>

        <div class="form__row">
          <div class="form__field">
            <label for="name">Name *</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>
          <div class="form__field">
            <label for="email">E-Mail *</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
        </div>

        <div class="form__row">
          <div class="form__field">
            <label for="telefon">Telefon (optional)</label>
            <input type="tel" id="telefon" name="telefon" autocomplete="tel" />
          </div>
          <div class="form__field">
            <label for="datum">Wunschdatum oder Zeitraum</label>
            <input type="text" id="datum" name="datum" placeholder="z.B. 15.06.2027 oder Sommer 2027" />
          </div>
        </div>

        <div class="form__row">
          <div class="form__field">
            <label for="gaeste">Gästezahl ungefähr</label>
            <input type="text" id="gaeste" name="gaeste" placeholder="z.B. 80" />
          </div>
          <div class="form__field">
            <label for="raum">Welcher Raum?</label>
            <select id="raum" name="raum">
              <option value="">— Egal / unsicher</option>
              <option value="Festsaal">Festsaal</option>
              <option value="Stüble">Martin Stüble</option>
              <option value="Beide">Beide</option>
              <option value="Außer-Haus">Außer Haus (Catering)</option>
            </select>
          </div>
        </div>

        <div class="form__field">
          <label for="nachricht">Was ist Ihnen wichtig? (Wünsche, Fragen, Sonstiges)</label>
          <textarea id="nachricht" name="nachricht" rows="6" placeholder="z.B. freie Trauung im Freien geplant, vegane Hauptspeisen, DJ schon gebucht ..."></textarea>
        </div>

        <div class="form__field form__field--check">
          <label>
            <input type="checkbox" name="datenschutz" required />
            Ich habe die <a href="/datenschutz" target="_blank">Datenschutzerklärung</a> gelesen und stimme zu, dass meine Angaben zur Bearbeitung meiner Anfrage gespeichert werden. *
          </label>
        </div>

        <button type="submit" class="btn btn--primary btn--arrow form__submit">Anfrage abschicken</button>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // URL-Parameter ?anlass=tagung vorausfüllen
  (function() {
    const params = new URLSearchParams(window.location.search);
    const anlass = params.get('anlass');

    if (anlass) {
      const map = {
        hochzeit: 'Hochzeit',
        tagung: 'Tagung & Versammlung',
        geburtstag: 'Geburtstag',
        kommunion: 'Kommunion & Konfirmation',
        firma: 'Firmenfeier',
        catering: 'Catering außer Haus',
      };
      const value = map[anlass.toLowerCase()] || anlass;
      const radio = document.querySelector(`input[name="anlass"][value="${value}"]`);
      if (radio) radio.checked = true;
    }
  })();

  // AJAX-Submit für robuste Bestätigungs-Seite
  (function() {
    const form = document.getElementById('anfrage-form');
    if (!form) return;

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const errorBox = document.getElementById('form-error');
      if (errorBox) errorBox.hidden = true;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Wird gesendet …';
      }

      const formData = new FormData(form);
      const params = new URLSearchParams();
      for (const [key, value] of formData) {
        params.append(key, value.toString());
      }

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString(),
        });

        if (response.ok) {
          window.location.href = '/danke';
        } else {
          throw new Error('Submit failed: ' + response.status);
        }
      } catch (err) {
        console.error('Form submit error:', err);
        if (errorBox) errorBox.hidden = false;
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Anfrage abschicken';
        }
      }
    });
  })();
</script>

<style>
  .contact-info {
    background: var(--c-cream-warm);
    border-left: 3px solid var(--c-blue);
    padding: var(--s-5);
    margin-bottom: var(--s-7);
    font-size: var(--t-md);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
  }

  .form .hp {
    position: absolute;
    left: -9999px;
    visibility: hidden;
  }

  .form__group { border: 0; padding: 0; }
  .form__legend {
    font-family: var(--f-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--t-sm);
    color: var(--c-mid);
    margin-bottom: var(--s-4);
    padding: 0;
  }

  .form__radio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-3);
  }
  @media (min-width: 600px) {
    .form__radio-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .form__radio-card {
    display: flex;
    flex-direction: column;
    padding: var(--s-4);
    border: 1px solid var(--c-line);
    border-radius: var(--r-md);
    background: var(--c-cream);
    cursor: pointer;
    transition: all var(--transition);
    position: relative;
  }
  .form__radio-card input { position: absolute; opacity: 0; pointer-events: none; }
  .form__radio-card:hover {
    border-color: var(--c-mokka);
    background: var(--c-cream-warm);
  }
  .form__radio-card:has(input:checked) {
    border-color: var(--c-mokka);
    background: var(--c-mokka-pale);
    box-shadow: 0 0 0 2px var(--c-mokka);
  }
  .form__radio-card__title {
    font-family: var(--f-body);
    font-weight: 600;
    font-size: var(--t-md);
    color: var(--c-anthracite);
    letter-spacing: -0.01em;
  }
  .form__radio-card__sub {
    font-size: var(--t-sm);
    color: var(--c-mid);
    margin-top: var(--s-1);
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
  }
  @media (min-width: 600px) {
    .form__row { grid-template-columns: 1fr 1fr; }
  }

  .form__field {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .form__field label {
    font-family: var(--f-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--t-sm);
    color: var(--c-mid);
  }
  .form__field input,
  .form__field select,
  .form__field textarea {
    font-family: var(--f-body);
    font-size: var(--t-base);
    padding: var(--s-3) var(--s-4);
    border: 1px solid var(--c-line);
    border-radius: var(--r-sm);
    background: var(--c-cream);
    color: var(--c-anthracite);
    transition: all var(--transition);
  }
  .form__field input:focus,
  .form__field select:focus,
  .form__field textarea:focus {
    outline: none;
    border-color: var(--c-mokka);
    box-shadow: 0 0 0 3px var(--c-mokka-pale);
  }

  .form__field--check label {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--s-3);
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--f-body);
    font-size: var(--t-sm);
    color: var(--c-mid);
    cursor: pointer;
  }
  .form__field--check input { margin-top: 4px; }

  .form__submit {
    align-self: flex-start;
    padding: var(--s-4) var(--s-7);
  }
  .form__submit:disabled {
    opacity: 0.6;
    cursor: wait;
  }
  .form__error {
    background: #fdecea;
    border: 1px solid #f5c2c0;
    border-radius: var(--r-md);
    padding: var(--s-4) var(--s-5);
    color: #8b1c19;
    font-size: var(--t-sm);
  }
  .form__error strong { display: block; margin-bottom: var(--s-1); }
</style>
