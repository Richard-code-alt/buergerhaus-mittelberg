---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { getCollection } from 'astro:content';

const title = 'Galerie — Hochzeiten im Bürgerhaus Mittelberg';
const description = 'Bilder echter Hochzeiten im Bürgerhaus Mittelberg — Festsaal, Trauungen, Tanzfläche, Catering. Eindrücke aus dem Allgäu.';

const bilder = (await getCollection('galerie')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);

const SITE_URL = Astro.site?.toString() || 'https://www.buergerhaus-mittelberg.de';
const gallerySchema = bilder.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Hochzeiten im Bürgerhaus Mittelberg',
  image: bilder.map((b) => ({
    '@type': 'ImageObject',
    contentUrl: new URL(b.data.bild, SITE_URL).toString(),
    description: b.data.alt,
  })),
} : null;

const placeholders = [
  { alt: 'Festsaal eingedeckt für Hochzeit', scene: 'venue', caption: 'Festsaal' },
  { alt: 'Hochzeitsmenü Hauptgang', scene: 'food', caption: 'Aus unserer Küche' },
  { alt: 'Freie Trauung im Stüble', scene: 'wedding', caption: 'Trauung' },
  { alt: 'Außenansicht Bürgerhaus mit Allgäuer Bergen', scene: 'mountain', caption: 'Mitten im Ort' },
  { alt: 'Festlich gedeckte Tafel', scene: 'table', caption: 'Eingedeckt' },
  { alt: 'Brautstrauß und Tischdekoration', scene: 'wedding', caption: 'Details' },
  { alt: 'Buffet mit regionalen Spezialitäten', scene: 'food', caption: 'Buffet' },
  { alt: 'Festsaal mit Bühne und Live-Band', scene: 'venue', caption: 'Bühne' },
  { alt: 'Sektempfang vor dem Haus', scene: 'mountain', caption: 'Vor dem Haus' },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Galerie', url: '/galerie' }]} />
    {gallerySchema && <script type="application/ld+json" set:html={JSON.stringify(gallerySchema)} />}
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">Galerie</span>
      <h1>Echte Feiern. Echte Bilder.</h1>
      <p class="lead mx-auto">
        Bilder aus echten Hochzeiten und Festen bei uns. Kein Stockfoto, kein Stadium-Marketing.
      </p>
      {bilder.length === 0 && (
        <p style="color: var(--c-soft); font-size: var(--t-sm);">
          <em>Hinweis: Aktuell zeigen wir Beispiel-Visuals. Profi-Fotos vom Sommer-Shoot
          ergänzen wir hier laufend.</em>
        </p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container--wide">
      <div class="gallery">
        {bilder.length > 0 ? (
          bilder.map((b) => (
            <figure class="gallery__item">
              <img src={b.data.bild} alt={b.data.alt} loading="lazy" />
              {b.data.caption && <figcaption>{b.data.caption}</figcaption>}
            </figure>
          ))
        ) : (
          placeholders.map((p) => (
            <ImagePlaceholder alt={p.alt} scene={p.scene as any} caption={p.caption} />
          ))
        )}
      </div>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">Ihre Hochzeit, Ihre Bilder</h2>
      <p class="lead mx-auto">Lassen Sie uns persönlich sprechen, was wir für Ihren Tag möglich machen.</p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">Termin anfragen</a>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-3);
  }
  @media (max-width: 800px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .gallery { grid-template-columns: 1fr; }
  }
  .gallery__item {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--c-cream-warm);
  }
  .gallery__item img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .gallery__item figcaption {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(13, 39, 65, 0.8) 0%, transparent 100%);
    color: var(--c-cream);
    padding: var(--s-5) var(--s-4) var(--s-3);
    font-family: var(--f-body);
    font-style: italic;
    font-weight: 500;
    font-size: var(--t-md);
  }
</style>
