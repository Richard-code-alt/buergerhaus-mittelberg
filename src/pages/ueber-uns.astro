---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import seitentexte from '../data/seiten/ueber-uns.json';

const title = 'Über das Bürgerhaus Mittelberg — Eure Gastgeber im Allgäu';
const description = 'Wer im Bürgerhaus Mittelberg kocht, wer den Saal vermietet, wer Ihre Hochzeit ausrichtet. Lernen Sie Ihre Gastgeber kennen.';

const absaetze = seitentexte.geschichte.split('\n\n').filter(Boolean);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Über uns', url: '/ueber-uns' }]} />
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">{seitentexte.hero_eyebrow}</span>
      <h1>{seitentexte.hero_titel}</h1>
      <p class="lead mx-auto">{seitentexte.hero_lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2" style="align-items: center;">
        <ImagePlaceholder
          alt={seitentexte.team_bild_alt}
          scene="venue"
          variant="tall"
          caption={seitentexte.team_bild_caption}
          src={seitentexte.team_bild || null}
        />
        <div>
          <span class="eyebrow">{seitentexte.wer_eyebrow}</span>
          <h2>{seitentexte.titel}</h2>
          {absaetze.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">{seitentexte.werte_eyebrow}</span>
        <h2 class="text-balance">{seitentexte.werte_titel}</h2>
      </div>

      <div class="grid grid-3">
        <div class="card">
          <span class="divider"></span>
          <h3>{seitentexte.werte_card_1_titel}</h3>
          <p>{seitentexte.werte_card_1_text}</p>
        </div>
        <div class="card">
          <span class="divider"></span>
          <h3>{seitentexte.werte_card_2_titel}</h3>
          <p>{seitentexte.werte_card_2_text}</p>
        </div>
        <div class="card">
          <span class="divider"></span>
          <h3>{seitentexte.werte_card_3_titel}</h3>
          <p>{seitentexte.werte_card_3_text}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <span class="eyebrow">{seitentexte.haus_eyebrow}</span>
      <h2>{seitentexte.haus_titel}</h2>
      <p>
        {seitentexte.haus_text}
      </p>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">{seitentexte.cta_titel}</h2>
      <p class="lead mx-auto">{seitentexte.cta_text}</p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">{seitentexte.cta_button}</a>
    </div>
  </section>
</BaseLayout>
