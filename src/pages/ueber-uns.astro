---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import seitentexte from '../data/seiten/ueber-uns.json';

const title = 'Über das Bürgerhaus Mittelberg — Eure Gastgeber im Allgäu';
const description = 'Wer im Bürgerhaus Mittelberg kocht, wer den Saal vermietet, wer eure Hochzeit ausrichtet. Lernt eure Gastgeber kennen.';

const absaetze = seitentexte.geschichte.split('\n\n').filter(Boolean);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Über uns', url: '/ueber-uns' }]} />
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">Über uns</span>
      <h1>Ihre Gastgeber</h1>
      <p class="lead mx-auto">Damit Sie wissen, mit wem Sie es zu tun haben — bevor wir uns kennenlernen.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2" style="align-items: center;">
        <ImagePlaceholder alt="Gastgeber-Team Bürgerhaus Mittelberg vor dem Haus" scene="venue" variant="tall" caption="Unser Team" />
        <div>
          <span class="eyebrow">Wer wir sind</span>
          <h2>{seitentexte.titel}</h2>
          {absaetze.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Was uns wichtig ist</span>
        <h2 class="text-balance">Drei Dinge, auf die Sie sich verlassen können</h2>
      </div>

      <div class="grid grid-3">
        <div class="card">
          <span class="divider"></span>
          <h3>Verlässlich</h3>
          <p>Was wir am Telefon vereinbaren, gilt auch am Tag der Veranstaltung. Sie bekommen keine Aufschläge in letzter Sekunde und keine vergessenen Zusagen.</p>
        </div>
        <div class="card">
          <span class="divider"></span>
          <h3>Eigene Küche</h3>
          <p>Wir kochen selbst — auch für 200 Gäste so, als wäre jeder Teller einzeln gedacht. Für uns ist das eine Frage des Anspruchs, nicht des Aufwands.</p>
        </div>
        <div class="card">
          <span class="divider"></span>
          <h3>Persönlich</h3>
          <p>Sie haben einen Ansprechpartner. Vom ersten Telefonat bis zum Abschiedskaffee am Sonntagmorgen sind es immer dieselben Gesichter.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <span class="eyebrow">Das Haus</span>
      <h2>Mehr als nur ein Festsaal</h2>
      <p>
        Das Bürgerhaus Mittelberg ist seit Jahrzehnten der Treffpunkt der Region. Hier werden Hochzeiten gefeiert, der traditionsreiche Mädeleball im Fasching getanzt, Konzerte gegeben und Vereinsfeste ausgerichtet. Wir führen das Haus mit dem Anspruch, dass das so bleibt — und freuen uns, wenn Ihre Veranstaltung dazu gehört.
      </p>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">Lernen Sie uns kennen</h2>
      <p class="lead mx-auto">Beim Besichtigungstermin haben Sie uns 30 bis 60 Minuten ganz für sich.</p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">Termin anfragen</a>
    </div>
  </section>
</BaseLayout>
