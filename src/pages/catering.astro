---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { getCollection } from 'astro:content';
import seitentexte from '../data/seiten/catering.json';

const title = 'Eigene Küche im Bürgerhaus Mittelberg — Hochzeitscatering Allgäu';
const description = 'Wir kochen für Ihre Hochzeit selbst. Regional, frisch, ohne externes Catering. Drei-Gänge-Menüs und Buffets aus dem Bürgerhaus Mittelberg.';

const menues = (await getCollection('menues')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Catering', url: '/catering' }]} />
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">{seitentexte.hero_eyebrow}</span>
      <h1>{seitentexte.titel}</h1>
      <p class="lead mx-auto">{seitentexte.lead}</p>
      <p class="mt-4">{seitentexte.story}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {menues.map((m, i) => (
          <article class={`card${m.data.highlight ? ' card--highlight' : ''}`}>
            <span class="eyebrow">Menü {i + 1}</span>
            <h3>{m.data.titel}</h3>
            <p><strong>Vorspeise</strong><br/>{m.data.vorspeise}</p>
            <p><strong>Hauptgang</strong><br/>{m.data.hauptgang}</p>
            <p><strong>Dessert</strong><br/>{m.data.dessert}</p>
          </article>
        ))}
      </div>

      <p class="text-center mt-6" style="color: var(--c-soft); font-size: var(--t-sm);">
        <em>{seitentexte.menues_hinweis}</em>
      </p>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="grid grid-2" style="align-items: center;">
        <ImagePlaceholder
          alt={seitentexte.buffet_bild_alt}
          scene="food"
          variant="tall"
          src={seitentexte.buffet_bild || null}
        />
        <div>
          <span class="eyebrow">{seitentexte.buffet_eyebrow}</span>
          <h2>{seitentexte.buffet_titel}</h2>
          <p>
            {seitentexte.buffet_text_1}
          </p>
          <p set:html={seitentexte.buffet_text_2.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <span class="eyebrow">{seitentexte.allergien_eyebrow}</span>
      <h2>{seitentexte.allergien_titel}</h2>
      <p>
        {seitentexte.allergien_text}
      </p>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container--narrow">
      <span class="eyebrow">{seitentexte.getraenke_eyebrow}</span>
      <h2>{seitentexte.getraenke_titel}</h2>
      <p>
        {seitentexte.getraenke_text}
      </p>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">{seitentexte.cta_titel}</h2>
      <p class="lead mx-auto">
        {seitentexte.cta_text}
      </p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">{seitentexte.cta_button}</a>
    </div>
  </section>
</BaseLayout>
