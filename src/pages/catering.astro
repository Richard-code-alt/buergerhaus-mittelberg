---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { getCollection } from 'astro:content';
import seitentexte from '../data/seiten/catering.json';

const title = 'Eigene Küche im Bürgerhaus Mittelberg — Hochzeitscatering Allgäu';
const description = 'Wir kochen für eure Hochzeit selbst. Regional, frisch, ohne externes Catering. Drei-Gänge-Menüs und Buffets aus dem Bürgerhaus Mittelberg.';

const menues = (await getCollection('menues')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Catering', url: '/catering' }]} />
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">Catering</span>
      <h1>{seitentexte.titel}</h1>
      <p class="lead mx-auto">{seitentexte.lead}</p>
      <p class="mt-4">{seitentexte.story}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {menues.map((m, i) => (
          <article class={`card${m.data.highlight ? ' card--highlight' : ''}`}>
            <span class="eyebrow">Menü {i + 1}</span>
            <h3>{m.data.titel}</h3>
            <p><strong>Vorspeise</strong><br/>{m.data.vorspeise}</p>
            <p><strong>Hauptgang</strong><br/>{m.data.hauptgang}</p>
            <p><strong>Dessert</strong><br/>{m.data.dessert}</p>
          </article>
        ))}
      </div>

      <p class="text-center mt-6" style="color: var(--c-soft); font-size: var(--t-sm);">
        <em>Beispielmenüs. Unsere aktuellen saisonalen Vorschläge bekommt ihr im Vorgespräch.</em>
      </p>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="grid grid-2" style="align-items: center;">
        <ImagePlaceholder
          alt="Festlich gedeckter Tisch mit Hochzeitsmenü im Bürgerhaus Mittelberg"
          scene="food"
          variant="tall"
        />
        <div>
          <span class="eyebrow">Buffet</span>
          <h2>Wenn ihr Vielfalt wollt</h2>
          <p>
            Ein Buffet ist die schönste Form, wenn eure Gäste sich austauschen sollen, statt drei
            Stunden am Platz zu sitzen. Vor- und Nachspeisen als kalte und warme Stationen, der
            Hauptgang heiß. Die Gäste suchen sich aus, wir füllen nach. Allergiker und Vegetarier
            bekommen ihre eigene Station.
          </p>
          <p>
            <strong>Beispielstationen:</strong> Allgäuer Käseplatte mit Bergkäse, Brotvielfalt vom regionalen Bäcker,
            Salatbar mit hausgemachten Dressings, warme Hauptspeisen-Station mit Allgäuer Klassikern und
            modernen Akzenten, Antipasti-Station, Dessert-Tisch mit Topfenmousse und Apfelküchle.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <span class="eyebrow">Allergien & Diät</span>
      <h2>Vegan, glutenfrei, individuell</h2>
      <p>
        Sagt uns spätestens 14 Tage vor der Hochzeit Bescheid, wer was braucht. Wir kochen separat,
        nicht „kann ja vom Hauptgang weglassen". Vegane Hauptspeisen, glutenfrei, laktosefrei,
        halal — alles geht, mit Vorlauf.
      </p>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container--narrow">
      <span class="eyebrow">Getränke</span>
      <h2>Bei uns auf Verbrauch</h2>
      <p>
        Getränke laufen über uns. Wir kalkulieren keinen Pauschalpreis pro Person, sondern rechnen
        nach Verbrauch ab. Bier vom Fass, Wein nach euren Wünschen ausgewählt, Sekt für den
        Empfang. Spirituosen-Auswahl an der Bar. Faire Margen, kein Wucher.
      </p>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">Menüs für eure Hochzeit zusammenstellen</h2>
      <p class="lead mx-auto">
        Wir besprechen Menü, Allergien und Wünsche persönlich.
      </p>
      <a href="/anfragen" class="btn btn--ghost btn--arrow mt-6">Anfrage stellen</a>
    </div>
  </section>
</BaseLayout>
