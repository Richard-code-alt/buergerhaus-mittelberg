---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import { getCollection } from 'astro:content';
import kontakt from '../data/kontakt.json';
import seitentexte from '../data/seiten/anfahrt.json';

const title = 'Anfahrt & Hotels — Bürgerhaus Mittelberg in Oy-Mittelberg';
const description = 'Anfahrt zum Bürgerhaus Mittelberg per Auto, Bahn, Flughafen. Parkplätze direkt vor dem Haus. Hotel-Empfehlungen für Ihre Gäste in Oy-Mittelberg.';

const allHotels = await getCollection('hotels');
const hotelsZuFuss = allHotels.filter((h) => h.data.kategorie === 'Zu Fuß erreichbar').sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
const hotelsAuto = allHotels.filter((h) => h.data.kategorie === 'Mit Auto').sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Anfahrt', url: '/anfahrt' }]} />
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">{seitentexte.hero_eyebrow}</span>
      <h1>{seitentexte.hero_titel}</h1>

      <div class="address-card mt-6">
        <p class="address-card__name">{kontakt.name}</p>
        <p>{kontakt.strasse}<br/>{kontakt.ort}</p>
        <p>
          <a href={`tel:+49${kontakt.telefon.replace(/\s/g, '').replace(/^0/, '')}`}>{kontakt.telefon}</a><br/>
          <a href={`mailto:${kontakt.email}`}>{kontakt.email}</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="route-card">
        <div class="route-card__address">
          <svg class="route-card__icon" viewBox="0 0 64 64" aria-hidden="true">
            <circle cx="32" cy="26" r="9" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <circle cx="32" cy="26" r="3" fill="currentColor"/>
            <path d="M 32 35 L 32 52 M 24 47 L 40 47" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="route-card__title">{seitentexte.route_titel}</p>
            <p class="route-card__sub">{seitentexte.route_sub}</p>
          </div>
        </div>

        <div class="route-card__actions">
          <p class="route-card__heading">{seitentexte.route_heading}</p>
          <div class="route-card__buttons">
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=Bürgerhaus+Mittelberg+Rotachstraße+8+Oy-Mittelberg&destination_place_id=B%C3%BCrgerhaus+Mittelberg"
              target="_blank"
              rel="noopener"
              class="btn btn--primary btn--arrow"
            >{seitentexte.route_button_google}</a>
            <a
              href="https://maps.apple.com/?daddr=Bürgerhaus+Mittelberg+Rotachstraße+8+Oy-Mittelberg&dirflg=d"
              target="_blank"
              rel="noopener"
              class="btn btn--secondary btn--arrow"
            >{seitentexte.route_button_apple}</a>
          </div>
          <p class="route-card__note">
            {seitentexte.route_note}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="grid grid-3">
        <div>
          <span class="eyebrow">{seitentexte.auto_eyebrow}</span>
          <h3>{seitentexte.auto_titel}</h3>
          <p>
            {seitentexte.auto_text}
          </p>
          <p style="font-size: var(--t-sm); color: var(--c-mid);">
            {seitentexte.auto_distanzen}
          </p>
        </div>
        <div>
          <span class="eyebrow">{seitentexte.bahn_eyebrow}</span>
          <h3>{seitentexte.bahn_titel}</h3>
          <p>
            {seitentexte.bahn_text}
          </p>
        </div>
        <div>
          <span class="eyebrow">{seitentexte.flug_eyebrow}</span>
          <h3>{seitentexte.flug_titel}</h3>
          <p set:html={seitentexte.flug_text.replace(/\n/g, '<br/>')}></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <span class="eyebrow">{seitentexte.parken_eyebrow}</span>
      <h2>{seitentexte.parken_titel}</h2>
      <p>
        {seitentexte.parken_text}
      </p>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">{seitentexte.hotels_eyebrow}</span>
        <h2>{seitentexte.hotels_titel}</h2>
        <p class="lead mx-auto">
          {seitentexte.hotels_lead}
        </p>
      </div>

      <div class="grid grid-2">
        <div>
          <h3>{seitentexte.hotels_titel_zufuss}</h3>
          <ul class="hotels">
            {hotelsZuFuss.map((h) => (
              <li>
                <strong>{h.data.name}</strong><br/>
                {h.data.adresse}{h.data.beschreibung ? ` · ${h.data.beschreibung}` : ''}
                {(h.data.bewertung || h.data.bewertungen_anzahl) && (
                  <><br/><span style="color: var(--c-mid); font-size: var(--t-sm);">
                    {h.data.bewertung && `⭐ ${h.data.bewertung}`}
                    {h.data.bewertung && h.data.bewertungen_anzahl && ' / '}
                    {h.data.bewertungen_anzahl && `${h.data.bewertungen_anzahl} Bewertungen`}
                  </span></>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3>{seitentexte.hotels_titel_auto}</h3>
          <ul class="hotels">
            {hotelsAuto.map((h) => (
              <li>
                <strong>{h.data.name}</strong><br/>
                {h.data.adresse}{h.data.beschreibung ? ` · ${h.data.beschreibung}` : ''}
                {(h.data.bewertung || h.data.bewertungen_anzahl) && (
                  <><br/><span style="color: var(--c-mid); font-size: var(--t-sm);">
                    {h.data.bewertung && `⭐ ${h.data.bewertung}`}
                    {h.data.bewertung && h.data.bewertungen_anzahl && ' / '}
                    {h.data.bewertungen_anzahl && `${h.data.bewertungen_anzahl} Bewertungen`}
                  </span></>
                )}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <p class="text-center mt-6" style="color: var(--c-soft); font-size: var(--t-sm);">
        <em>{seitentexte.hotels_hinweis}</em>
      </p>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">{seitentexte.cta_titel}</h2>
      <p class="lead mx-auto">
        {seitentexte.cta_text}
      </p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">{seitentexte.cta_button}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .address-card {
    background: var(--c-cream-warm);
    border-left: 3px solid var(--c-blue);
    padding: var(--s-5);
    text-align: left;
    display: inline-block;
    font-size: var(--t-md);
  }
  .address-card__name {
    font-family: var(--f-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    font-size: var(--t-md);
    margin-bottom: var(--s-2);
  }

  .route-card {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    border: 1px solid var(--c-line);
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--c-cream);
  }

  .route-card__address {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    padding: var(--s-6);
    background: var(--c-cream-warm);
    border-bottom: 1px solid var(--c-line);
  }
  .route-card__icon {
    width: 48px; height: 48px;
    color: var(--c-mokka);
    flex-shrink: 0;
  }
  .route-card__title {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    font-weight: 500;
    color: var(--c-anthracite);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .route-card__sub {
    color: var(--c-mid);
    margin: var(--s-1) 0 0;
    font-size: var(--t-sm);
  }

  .route-card__actions {
    padding: var(--s-6);
    display: flex; flex-direction: column;
    gap: var(--s-4);
  }
  @media (min-width: 800px) {
    .route-card__actions { padding: var(--s-7); }
  }

  .route-card__heading {
    font-family: var(--f-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: var(--t-xs);
    color: var(--c-mokka);
    margin: 0;
  }
  .route-card__buttons {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .route-card__buttons .btn {
    justify-content: space-between;
    width: 100%;
  }
  .route-card__note {
    font-size: var(--t-sm);
    color: var(--c-mid);
    margin: 0;
    line-height: 1.5;
  }

  .hotels { display: flex; flex-direction: column; gap: var(--s-4); margin-top: var(--s-3); }
  .hotels li {
    border-left: 2px solid var(--c-line);
    padding-left: var(--s-4);
    line-height: 1.5;
  }
</style>
