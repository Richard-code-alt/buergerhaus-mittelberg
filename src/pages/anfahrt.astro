---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import { getCollection } from 'astro:content';
import kontakt from '../data/kontakt.json';

const title = 'Anfahrt & Hotels — Bürgerhaus Mittelberg in Oy-Mittelberg';
const description = 'Anfahrt zum Bürgerhaus Mittelberg per Auto, Bahn, Flughafen. Parkplätze direkt vor dem Haus. Hotel-Empfehlungen für Ihre Gäste in Oy-Mittelberg.';

const allHotels = await getCollection('hotels');
const hotelsZuFuss = allHotels.filter((h) => h.data.kategorie === 'Zu Fuß erreichbar').sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
const hotelsAuto = allHotels.filter((h) => h.data.kategorie === 'Mit Auto').sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Anfahrt', url: '/anfahrt' }]} />
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">Anfahrt</span>
      <h1>So finden Sie uns</h1>

      <div class="address-card mt-6">
        <p class="address-card__name">{kontakt.name}</p>
        <p>{kontakt.strasse}<br/>{kontakt.ort}</p>
        <p>
          <a href={`tel:+49${kontakt.telefon.replace(/\s/g, '').replace(/^0/, '')}`}>{kontakt.telefon}</a><br/>
          <a href={`mailto:${kontakt.email}`}>{kontakt.email}</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="route-card">
        <div class="route-card__address">
          <svg class="route-card__icon" viewBox="0 0 64 64" aria-hidden="true">
            <circle cx="32" cy="26" r="9" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <circle cx="32" cy="26" r="3" fill="currentColor"/>
            <path d="M 32 35 L 32 52 M 24 47 L 40 47" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="route-card__title">Rotachstraße 8</p>
            <p class="route-card__sub">87466 Oy-Mittelberg · Allgäu</p>
          </div>
        </div>

        <div class="route-card__actions">
          <p class="route-card__heading">Route berechnen</p>
          <div class="route-card__buttons">
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=Bürgerhaus+Mittelberg+Rotachstraße+8+Oy-Mittelberg&destination_place_id=B%C3%BCrgerhaus+Mittelberg"
              target="_blank"
              rel="noopener"
              class="btn btn--primary btn--arrow"
            >Google Maps</a>
            <a
              href="https://maps.apple.com/?daddr=Bürgerhaus+Mittelberg+Rotachstraße+8+Oy-Mittelberg&dirflg=d"
              target="_blank"
              rel="noopener"
              class="btn btn--secondary btn--arrow"
            >Apple Maps</a>
          </div>
          <p class="route-card__note">
            Klick auf einen Button öffnet Ihre Navi-App mit der Route ab Ihrem Standort.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="grid grid-3">
        <div>
          <span class="eyebrow">Mit dem Auto</span>
          <h3>Über die A7</h3>
          <p>
            A7 Ausfahrt Nesselwang, dann B309 Richtung Wertach, in Oy-Mittelberg ins Ortsteil
            Mittelberg abbiegen. Wir liegen direkt an der Hauptstraße im Ortskern.
          </p>
          <p style="font-size: var(--t-sm); color: var(--c-mid);">
            München 1:45 h · Stuttgart 2:15 h · Friedrichshafen 1:00 h · Innsbruck 1:30 h
          </p>
        </div>
        <div>
          <span class="eyebrow">Mit der Bahn</span>
          <h3>Bahnhof Oy-Mittelberg</h3>
          <p>
            Drei Minuten mit dem Auto entfernt. Stündlich Verbindungen Richtung Kempten und Pfronten.
          </p>
        </div>
        <div>
          <span class="eyebrow">Mit dem Flugzeug</span>
          <h3>FMM, MUC oder INN</h3>
          <p>
            Memmingen Allgäu (FMM): 50 km · 50 min<br/>
            München (MUC): 175 km · 1:45 h<br/>
            Innsbruck (INN): 110 km · 1:30 h
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <span class="eyebrow">Parken</span>
      <h2>Direkt vor dem Haus</h2>
      <p>
        Direkt vor dem Bürgerhaus stehen ausreichend kostenfreie Parkplätze für Ihre Gäste.
        Bei sehr großen Hochzeiten weisen wir Zusatzflächen aus.
      </p>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Übernachten</span>
        <h2>Hotels in Oy-Mittelberg</h2>
        <p class="lead mx-auto">
          Damit Ihre Gäste nicht weit fahren müssen, hier eine Auswahl an Häusern in Gehweite oder
          kurzer Fahrt. Reservierungen laufen direkt mit den Häusern.
        </p>
      </div>

      <div class="grid grid-2">
        <div>
          <h3>Im Ortskern (zu Fuß)</h3>
          <ul class="hotels">
            {hotelsZuFuss.map((h) => (
              <li>
                <strong>{h.data.name}</strong><br/>
                {h.data.adresse}{h.data.beschreibung ? ` · ${h.data.beschreibung}` : ''}
                {(h.data.bewertung || h.data.bewertungen_anzahl) && (
                  <><br/><span style="color: var(--c-mid); font-size: var(--t-sm);">
                    {h.data.bewertung && `⭐ ${h.data.bewertung}`}
                    {h.data.bewertung && h.data.bewertungen_anzahl && ' / '}
                    {h.data.bewertungen_anzahl && `${h.data.bewertungen_anzahl} Bewertungen`}
                  </span></>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3>Wenige Minuten Fahrt</h3>
          <ul class="hotels">
            {hotelsAuto.map((h) => (
              <li>
                <strong>{h.data.name}</strong><br/>
                {h.data.adresse}{h.data.beschreibung ? ` · ${h.data.beschreibung}` : ''}
                {(h.data.bewertung || h.data.bewertungen_anzahl) && (
                  <><br/><span style="color: var(--c-mid); font-size: var(--t-sm);">
                    {h.data.bewertung && `⭐ ${h.data.bewertung}`}
                    {h.data.bewertung && h.data.bewertungen_anzahl && ' / '}
                    {h.data.bewertungen_anzahl && `${h.data.bewertungen_anzahl} Bewertungen`}
                  </span></>
                )}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <p class="text-center mt-6" style="color: var(--c-soft); font-size: var(--t-sm);">
        <em>Auf Wunsch melden wir Ihre Hochzeitsgesellschaft bei den Häusern an.</em>
      </p>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">Vorbeikommen, Saal anschauen</h2>
      <p class="lead mx-auto">
        Persönliche Eindrücke schlagen jede Website. Vereinbart einen Besichtigungstermin.
      </p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">Termin anfragen</a>
    </div>
  </section>
</BaseLayout>

<style>
  .address-card {
    background: var(--c-cream-warm);
    border-left: 3px solid var(--c-blue);
    padding: var(--s-5);
    text-align: left;
    display: inline-block;
    font-size: var(--t-md);
  }
  .address-card__name {
    font-family: var(--f-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    font-size: var(--t-md);
    margin-bottom: var(--s-2);
  }

  .route-card {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    border: 1px solid var(--c-line);
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--c-cream);
  }

  .route-card__address {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    padding: var(--s-6);
    background: var(--c-cream-warm);
    border-bottom: 1px solid var(--c-line);
  }
  .route-card__icon {
    width: 48px; height: 48px;
    color: var(--c-mokka);
    flex-shrink: 0;
  }
  .route-card__title {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    font-weight: 500;
    color: var(--c-anthracite);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .route-card__sub {
    color: var(--c-mid);
    margin: var(--s-1) 0 0;
    font-size: var(--t-sm);
  }

  .route-card__actions {
    padding: var(--s-6);
    display: flex; flex-direction: column;
    gap: var(--s-4);
  }
  @media (min-width: 800px) {
    .route-card__actions { padding: var(--s-7); }
  }

  .route-card__heading {
    font-family: var(--f-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: var(--t-xs);
    color: var(--c-mokka);
    margin: 0;
  }
  .route-card__buttons {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .route-card__buttons .btn {
    justify-content: space-between;
    width: 100%;
  }
  .route-card__note {
    font-size: var(--t-sm);
    color: var(--c-mid);
    margin: 0;
    line-height: 1.5;
  }

  .hotels { display: flex; flex-direction: column; gap: var(--s-4); margin-top: var(--s-3); }
  .hotels li {
    border-left: 2px solid var(--c-line);
    padding-left: var(--s-4);
    line-height: 1.5;
  }
</style>
