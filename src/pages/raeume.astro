---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import seitentexte from '../data/seiten/raeume.json';

const title = 'Festsaal & Stüble — Räume im Bürgerhaus Mittelberg';
const description = 'Festsaal für bis zu 250 Gäste mit großer Bühne, Martin Stüble für intime Feiern bis 50 Personen. Beide Räume im Detail mit Maßen und Ausstattung.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Räume', url: '/raeume' }]} />
  </Fragment>
  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">{seitentexte.hero_eyebrow}</span>
      <h1>{seitentexte.hero_titel}</h1>
      <p class="lead">
        {seitentexte.hero_lead}
      </p>
    </div>
  </section>

  <section id="festsaal" class="section">
    <div class="container">
      <div class="grid grid-2" style="align-items: center; gap: var(--s-8);">
        <div>
          <ImagePlaceholder
            alt={seitentexte.festsaal_bild_alt}
            scene="venue"
            variant="tall"
            src={seitentexte.festsaal_bild || null}
          />
        </div>
        <div>
          <span class="eyebrow">{seitentexte.festsaal_eyebrow}</span>
          <h2>{seitentexte.festsaal_titel}</h2>
          <p>
            {seitentexte.festsaal_text}
          </p>

          <table class="specs mt-6">
            <tbody>
              {seitentexte.festsaal_specs.map((spec: { label: string; wert: string }) => (
                <tr><th>{spec.label}</th><td>{spec.wert}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-8">
        <h3>{seitentexte.festsaal_bestuhlung_titel}</h3>
        <ul class="bullets">
          {seitentexte.festsaal_bestuhlung.map((item: { punkt: string }) => <li>{item.punkt}</li>)}
        </ul>
        <a href="/anfragen" class="btn btn--primary btn--arrow mt-6">{seitentexte.festsaal_button}</a>
      </div>
    </div>
  </section>

  <section id="stueble" class="section section--cream-warm">
    <div class="container">
      <div class="grid grid-2" style="align-items: center; gap: var(--s-8);">
        <div>
          <span class="eyebrow">{seitentexte.stueble_eyebrow}</span>
          <h2>{seitentexte.stueble_titel}</h2>
          <p>
            {seitentexte.stueble_text}
          </p>

          <table class="specs mt-6">
            <tbody>
              {seitentexte.stueble_specs.map((spec: { label: string; wert: string }) => (
                <tr><th>{spec.label}</th><td>{spec.wert}</td></tr>
              ))}
            </tbody>
          </table>

          <a href="/anfragen" class="btn btn--secondary btn--arrow mt-6">{seitentexte.stueble_button}</a>
        </div>
        <div>
          <ImagePlaceholder
            alt={seitentexte.stueble_bild_alt}
            scene="table"
            variant="tall"
            src={seitentexte.stueble_bild || null}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <span class="eyebrow">{seitentexte.aussen_eyebrow}</span>
      <h2>{seitentexte.aussen_titel}</h2>
      <p>
        {seitentexte.aussen_text_1}
      </p>
      <p>
        {seitentexte.aussen_text_2}
      </p>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">{seitentexte.cta_titel}</h2>
      <p class="lead" style="color: var(--c-cream); opacity: 0.9;">
        {seitentexte.cta_text}
      </p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">{seitentexte.cta_button}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .bullets { padding-left: var(--s-5); list-style: disc; }
  .bullets li { padding: var(--s-2) 0; }
</style>
