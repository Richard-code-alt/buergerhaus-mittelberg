---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { getCollection } from 'astro:content';
import seitentexte from '../data/seiten/startseite.json';
import kontakt from '../data/kontakt.json';

const title = 'Bürgerhaus Mittelberg — Hochzeit & Eventlocation Allgäu';
const description = 'Eventlocation in Oy-Mittelberg, Allgäu: Festsaal für 260 Gäste, eigene Küche, persönliche Gastgeber. Hochzeit, Tagung, Geburtstag — Termin anfragen.';

const pakete = (await getCollection('pakete')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);

const slugMap: Record<string, string> = {
  'Standesamt im Stüble': 'standesamt',
  'Hochzeit im Festsaal': 'festsaal',
  'Komplett-Hochzeit': 'komplett',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': ['EventVenue', 'LocalBusiness'],
  name: kontakt.name,
  description: 'Hochzeitslocation und Eventsaal in Oy-Mittelberg im Allgäu mit eigener Küche. Festsaal für bis zu 260 Personen, separates Stüble für bis zu 50 Personen.',
  url: 'https://www.buergerhaus-mittelberg.de/',
  telephone: '+49-8366-1300',
  email: kontakt.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: kontakt.strasse,
    addressLocality: 'Oy-Mittelberg',
    postalCode: '87466',
    addressRegion: 'Bayern',
    addressCountry: 'DE',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 47.642980, longitude: 10.437750 },
  image: 'https://www.buergerhaus-mittelberg.de/og-default.jpg',
  logo: 'https://www.buergerhaus-mittelberg.de/logo.png',
  maximumAttendeeCapacity: 260,
  amenityFeature: [
    { '@type': 'LocationFeatureSpecification', name: 'Bühne', value: '9×6 m' },
    { '@type': 'LocationFeatureSpecification', name: 'Eigene Küche', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Parkplätze', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Tanzfläche', value: true },
  ],
  sameAs: [kontakt.instagram, kontakt.facebook].filter(Boolean),
  priceRange: '€€',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      description: 'Termine nach Vereinbarung',
    },
  ],
  makesOffer: pakete.map((p) => ({
    '@type': 'Offer',
    name: p.data.titel,
    description: p.data.kurz,
    price: p.data.preis,
    priceCurrency: 'EUR',
    eligibleQuantity: {
      '@type': 'QuantitativeValue',
      minValue: p.data.min_personen,
      unitText: 'Personen',
    },
  })),
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <section class="hero">
    <canvas class="hero__canvas" aria-hidden="true" data-hero-canvas></canvas>
    <div class="hero__inner">
      <div class="hero__copy">
        <span class="eyebrow hero__eyebrow">Eventlocation Allgäu</span>
        <h1 class="hero__title">
          Eure Hochzeit<br/>
          im <span class="hero__title-accent">Allgäu</span>
        </h1>
        <p class="hero__lead">{seitentexte.hero_lead}</p>
        <div class="hero__actions">
          <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg">Termin anfragen</a>
          <a href="/raeume" class="btn btn--secondary">Räume ansehen</a>
        </div>

        <div class="hero__stats">
          <div><strong>260</strong><span>Plätze im Festsaal</span></div>
          <div><strong>9 × 6 m</strong><span>Profibühne</span></div>
          <div><strong>1</strong><span>Ansprechpartner</span></div>
        </div>
      </div>
      <div class="hero__visual">
        <ImagePlaceholder
          alt="Bürgerhaus Mittelberg in Oy-Mittelberg vor den Allgäuer Bergen"
          variant="hero"
          scene="mountain"
          caption="Mitten im Allgäu"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Anlässe</span>
        <h2 class="text-balance">Hochzeit, Tagung,<br/>Geburtstag & mehr</h2>
        <p class="lead text-balance mx-auto" style="margin: var(--s-5) auto 0;">
          Hochzeit ist unser Schwerpunkt, aber bei uns finden auch Tagungen, Geburtstage, Kommunion und Firmenfeiern den passenden Rahmen. Catering bieten wir auf Wunsch auch außer Haus.
        </p>
        <a href="/anlaesse" class="btn btn--secondary btn--arrow mt-6">Alle Anlässe</a>
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Aus einer Hand</span>
        <h2 class="text-balance">{seitentexte.usp_titel}<br/><span style="color: var(--c-mokka);">Alles unter einem Dach.</span></h2>
        <p class="lead text-balance mx-auto" style="margin: var(--s-5) auto 0;">{seitentexte.usp_lead}</p>
      </div>

      <div class="grid grid-3">
        <article class="card">
          <span class="divider"></span>
          <h3>Festsaal mit Bühne</h3>
          <p>Bis zu 260 Gäste, Bühne 9 × 6 m, Tonanlage und Licht. Alpenländischer Charakter mit gemütlich-rustikaler Atmosphäre und moderner Technik.</p>
        </article>
        <article class="card">
          <span class="divider"></span>
          <h3>Eigene Küche</h3>
          <p>Wir kochen selbst — regional und frisch, abgestimmt auf Ihre Wünsche. Ihre Gäste merken, dass jemand für sie gekocht hat, der weiß, was er tut.</p>
        </article>
        <article class="card">
          <span class="divider"></span>
          <h3>Persönliche Gastgeber</h3>
          <p>Sebastian Künzel und sein Team sind vom ersten Telefonat bis zum Abschiedskaffee am Sonntagmorgen für Sie da — immer dieselben Gesichter.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Unsere Räume</span>
        <h2 class="text-balance">Zwei Räume.<br/>Für jeden Anlass der passende.</h2>
      </div>

      <div class="grid grid-2">
        <div>
          <ImagePlaceholder
            alt="Festsaal mit Bühne und Tanzfläche"
            scene="venue"
            caption="Festsaal"
          />
          <h3 class="mt-5">Festsaal</h3>
          <p>260 Plätze, große Bühne, Tanzfläche, Bar. Für die große Feier ab etwa 80 Gästen — egal ob Ihre Live-Band, ein DJ oder Reden auf der Bühne, der Saal trägt jede Stimmung mit.</p>
          <a href="/raeume#festsaal" class="btn btn--secondary btn--arrow mt-3">Mehr zum Festsaal</a>
        </div>
        <div>
          <ImagePlaceholder
            alt="Martin Stüble, holzvertäfelte Sitzgruppe"
            scene="table"
            caption="Martin Stüble"
          />
          <h3 class="mt-5">Martin Stüble</h3>
          <p>Bis 50 Plätze, intim und stimmungsvoll. Für die kleine Hochzeit, die freie Trauung im Familienkreis, einen Sektempfang oder den Brunch am Tag danach.</p>
          <a href="/raeume#stueble" class="btn btn--secondary btn--arrow mt-3">Mehr zum Stüble</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Hochzeitspakete</span>
        <h2 class="text-balance">Drei Pakete. Klar kalkuliert.</h2>
        <p class="lead mx-auto">Transparent und verständlich — was Sie sehen, ist was Sie bezahlen.</p>
      </div>

      <div class="grid grid-3">
        {pakete.map((p, i) => {
          const slug = slugMap[p.data.titel] || `paket-${p.data.reihenfolge}`;
          return (
            <article class={`card${p.data.highlight ? ' card--highlight' : ''}`}>
              <span class="card__tier">Paket {i + 1}</span>
              <h3>{p.data.titel}</h3>
              <p>{p.data.kurz}</p>
              <p class="card__price">ab <strong>{p.data.preis} €</strong> p. P.<br/><small>min. {p.data.min_personen} Personen</small></p>
              <a href={`/hochzeit#${slug}`} class={`btn ${p.data.highlight ? 'btn--primary' : 'btn--secondary'} btn--arrow`}>Details</a>
            </article>
          );
        })}
      </div>

      <div class="text-center mt-8">
        <a href="/hochzeit" class="btn btn--primary btn--arrow">Alle Pakete im Detail</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow text-center">
      <span class="eyebrow">Trauung</span>
      <h2 class="text-balance">Standesamtlich, kirchlich oder frei.</h2>
      <p class="lead text-pretty mx-auto">
        Im Stüble heiraten Sie im Familienkreis, im Festsaal in großer Runde.
        Bei gutem Wetter auch draußen vor dem Haus, mit Blick auf die Allgäuer Berge.
        Das Standesamt Oy-Mittelberg ist in wenigen Minuten mit dem Auto erreichbar.
      </p>
      <a href="/hochzeit#trauung" class="btn btn--secondary btn--arrow mt-5">Trauung-Optionen</a>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="grid grid-2" style="align-items: center;">
        <ImagePlaceholder alt="Aus unserer Küche — Hochzeitsmenü" scene="food" caption="Aus unserer Küche" />
        <div>
          <span class="eyebrow">Catering</span>
          <h2 class="text-balance">Wir kochen selbst.</h2>
          <p>
            Sebastian Künzel kocht persönlich für Ihre Feier. Allgäuer Wurzeln,
            regional und frisch — Drei-Gänge-Menüs, Buffets oder etwas dazwischen.
          </p>
          <p>Allergien, vegetarische oder vegane Gäste? Sagen Sie uns rechtzeitig Bescheid, wir kochen für jeden separat.</p>
          <a href="/catering" class="btn btn--secondary btn--arrow mt-3">Menüs ansehen</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2" style="align-items: center;">
        <ImagePlaceholder alt="Sebastian Künzel und Team vor dem Bürgerhaus Mittelberg" scene="venue" caption="Unser Team" />
        <div>
          <span class="eyebrow">Wir</span>
          <h2 class="text-balance">Sebastian Künzel & Team</h2>
          <p>
            Persönlich, herzlich, mit Wurzeln im Allgäu. Wir kochen selbst, kümmern uns um jedes Detail und sind vom ersten Telefonat bis zum Abschiedskaffee am Sonntagmorgen für Sie da.
          </p>
          <p>
            Schauen Sie auch gerne auf unseren Social-Media-Kanälen vorbei — dort zeigen wir Eindrücke aus dem Alltag im Bürgerhaus.
          </p>
          <div class="social-links mt-4">
            {kontakt.instagram && (
              <a href={kontakt.instagram} target="_blank" rel="noopener" class="social-link">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.85 5.85 0 0 0-2.13 1.38A5.85 5.85 0 0 0 .63 4.14c-.3.76-.5 1.64-.56 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.81.74 1.5 1.38 2.13a5.85 5.85 0 0 0 2.13 1.38c.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.85 5.85 0 0 0 2.13-1.38 5.85 5.85 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91C23.99 15.67 24 15.26 24 12s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.85 5.85 0 0 0-1.38-2.13A5.85 5.85 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84zm0 10.16A4 4 0 1 1 16 12a4 4 0 0 1-4 4zm6.4-11.85a1.44 1.44 0 1 0 1.44 1.44 1.44 1.44 0 0 0-1.44-1.44z"/>
                </svg>
                <span>Instagram</span>
              </a>
            )}
            {kontakt.facebook && (
              <a href={kontakt.facebook} target="_blank" rel="noopener" class="social-link">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.07A12 12 0 1 0 10.13 24v-8.44H7.08v-3.5h3.05V9.41c0-3.02 1.8-4.7 4.55-4.7 1.32 0 2.7.24 2.7.24v2.97h-1.52c-1.5 0-1.96.93-1.96 1.89v2.26h3.34l-.53 3.5h-2.81V24A12 12 0 0 0 24 12.07z"/>
                </svg>
                <span>Facebook</span>
              </a>
            )}
          </div>
          <a href="/ueber-uns" class="btn btn--secondary btn--arrow mt-5">Mehr über uns</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container--narrow text-center">
      <span class="eyebrow">Anfahrt</span>
      <h2 class="text-balance">Mitten im Ort.</h2>
      <p class="lead text-pretty mx-auto">
        {kontakt.strasse}, {kontakt.ort.replace(/\d+\s+/, '')}. Direkt an der Hauptstraße im Ortsteil Mittelberg, mit kostenfreien Parkplätzen vor dem Haus. Standesamt und Bahnhof Oy-Mittelberg sind in drei Minuten mit dem Auto erreichbar.
      </p>
      <a href="/anfahrt" class="btn btn--secondary btn--arrow mt-5">Anfahrt & Hotels</a>
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <span class="eyebrow">Anfrage</span>
      <h2 class="text-balance">Bereit, Ihre Feier zu planen?</h2>
      <p class="lead mx-auto">
        Schreiben Sie uns Ihr Wunschdatum, die ungefähre Gästezahl und was Ihnen wichtig ist. Wir melden uns innerhalb von 48 Stunden mit einem konkreten Vorschlag.
      </p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">Termin anfragen</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--s-9) 0 var(--s-9);
    background:
      radial-gradient(circle at 80% 20%, rgba(122, 79, 48, 0.06) 0%, transparent 50%),
      radial-gradient(circle at 10% 80%, rgba(29, 79, 125, 0.05) 0%, transparent 50%),
      var(--c-cream);
    position: relative;
    overflow: hidden;
  }
  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.85;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__canvas { display: none; }
  }
  .hero__inner {
    position: relative;
    z-index: 1;
  }
  @media (min-width: 720px) {
    .hero { padding: var(--s-10) 0 var(--s-10); }
  }
  .hero__inner {
    display: grid; grid-template-columns: 1fr; gap: var(--s-6);
    padding: 0 var(--s-4); margin: 0 auto;
    max-width: var(--w-wide);
  }
  @media (min-width: 720px) { .hero__inner { padding: 0 var(--s-6); gap: var(--s-7); } }
  @media (min-width: 1000px) {
    .hero__inner { grid-template-columns: 1.1fr 1fr; gap: var(--s-8); align-items: center; }
  }

  .hero__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2.75rem, 9vw, 5.5rem);
    line-height: 1.0;
    margin-bottom: var(--s-5);
    color: var(--c-anthracite);
    letter-spacing: -0.035em;
    text-transform: none;
    text-align: center;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  @media (min-width: 1000px) {
    .hero__title { text-align: left; }
  }
  .hero__title-accent {
    color: var(--c-mokka);
    font-style: normal;
    font-weight: 400;
  }

  .hero__copy {
    text-align: center;
  }
  .hero__eyebrow {
    justify-content: center;
  }
  @media (min-width: 1000px) {
    .hero__copy { text-align: left; }
    .hero__eyebrow { justify-content: flex-start; }
  }

  .hero__lead {
    font-size: var(--t-md);
    color: var(--c-mid); line-height: 1.6;
    margin: 0 auto var(--s-6);
    max-width: 36rem;
  }
  @media (min-width: 1000px) {
    .hero__lead { margin: 0 0 var(--s-6); }
  }

  .hero__actions {
    display: flex; gap: var(--s-3); flex-wrap: wrap;
    margin-bottom: var(--s-7);
    justify-content: center;
  }
  @media (min-width: 1000px) {
    .hero__actions { justify-content: flex-start; }
  }

  .hero__stats {
    display: flex; gap: var(--s-5); flex-wrap: wrap;
    padding-top: var(--s-5);
    border-top: 1px solid var(--c-line);
    justify-content: center;
  }
  @media (min-width: 1000px) {
    .hero__stats { justify-content: flex-start; }
  }
  .hero__stats > div { display: flex; flex-direction: column; gap: var(--s-1); }
  .hero__stats strong {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    font-weight: 400;
    color: var(--c-blue);
    line-height: 1;
  }
  .hero__stats span {
    font-size: var(--t-xs);
    color: var(--c-mid);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero__visual { width: 100%; }

  .card__tier {
    font-family: var(--f-display);
    text-transform: uppercase; letter-spacing: 0.18em;
    font-size: var(--t-xs);
    color: var(--c-brass);
  }
  .card__price {
    font-family: var(--f-display);
    font-size: var(--t-md);
    color: var(--c-anthracite);
    border-top: 1px solid var(--c-line);
    padding-top: var(--s-4);
    margin: auto 0 var(--s-3);
    line-height: 1.2;
  }
  .card__price strong {
    font-size: var(--t-xl);
    color: var(--c-blue);
    display: inline-block;
    margin-right: var(--s-1);
  }
  .card__price small {
    font-family: var(--f-body);
    color: var(--c-mid);
    font-size: var(--t-xs);
    text-transform: none;
    letter-spacing: 0;
  }
  .social-links {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: var(--s-2) var(--s-4);
    border: 1px solid var(--c-line);
    border-radius: var(--r-pill);
    color: var(--c-anthracite);
    background: var(--c-cream);
    font-size: var(--t-sm);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition);
  }
  .social-link:hover {
    border-color: var(--c-mokka);
    color: var(--c-mokka);
    transform: translateY(-1px);
  }
  .social-link svg { flex-shrink: 0; }
</style>

<script is:inline>
  (function() {
    const canvas = document.querySelector('[data-hero-canvas]');
    if (!canvas) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (reducedMotion.matches) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    let particles = [];
    let rafId = null;
    let mouseX = -9999;
    let mouseY = -9999;

    // Brand colors as RGB strings — for canvas we use rgba()
    const colors = [
      [122, 79, 48],   // Mokka
      [184, 148, 90],  // Brass-warm
      [212, 180, 130], // Lighter mokka
      [29, 79, 125],   // Blue (sehr selten, für Akzent)
    ];

    function resize() {
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.scale(dpr, dpr);
      initParticles();
    }

    function initParticles() {
      // Mobile reduziert: weniger Partikel
      const isMobile = width < 720;
      const count = isMobile ? 18 : 35;
      particles = [];
      for (let i = 0; i < count; i++) {
        particles.push(makeParticle());
      }
    }

    function makeParticle() {
      const colorIdx = Math.random() < 0.05 ? 3 : Math.floor(Math.random() * 3);
      return {
        x: Math.random() * width,
        y: Math.random() * height,
        // Sehr langsame Bewegung — vertical drift nach oben
        vx: (Math.random() - 0.5) * 0.15,
        vy: -0.05 - Math.random() * 0.15,
        radius: 0.8 + Math.random() * 1.8,
        alpha: 0.15 + Math.random() * 0.35,
        // Pulsierender Glow
        pulseSpeed: 0.005 + Math.random() * 0.01,
        pulseOffset: Math.random() * Math.PI * 2,
        color: colors[colorIdx],
      };
    }

    function draw(time) {
      ctx.clearRect(0, 0, width, height);

      for (const p of particles) {
        // Pulsierender Alpha-Wert für sanftes Glimmen
        const pulse = (Math.sin(time * p.pulseSpeed + p.pulseOffset) + 1) / 2;
        const currentAlpha = p.alpha * (0.5 + pulse * 0.5);

        // Mouse-Interaktion: Partikel weichen sanft aus
        const dx = p.x - mouseX;
        const dy = p.y - mouseY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const repelRadius = 80;
        if (dist < repelRadius && dist > 0) {
          const force = (1 - dist / repelRadius) * 0.5;
          p.x += (dx / dist) * force;
          p.y += (dy / dist) * force;
        }

        // Position aktualisieren
        p.x += p.vx;
        p.y += p.vy;

        // Wrap around — Partikel kommen unten wieder rein, wenn sie oben raus sind
        if (p.y < -10) {
          p.y = height + 10;
          p.x = Math.random() * width;
        }
        if (p.x < -10) p.x = width + 10;
        if (p.x > width + 10) p.x = -10;

        // Glow-Effekt: zwei Kreise, äußerer transparent
        const [r, g, b] = p.color;

        // Äußerer Glow
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius * 4, 0, Math.PI * 2);
        const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius * 4);
        gradient.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${currentAlpha * 0.4})`);
        gradient.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
        ctx.fillStyle = gradient;
        ctx.fill();

        // Kern-Punkt
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${currentAlpha})`;
        ctx.fill();
      }

      rafId = requestAnimationFrame(draw);
    }

    function onMouseMove(e) {
      const rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    }

    function onMouseLeave() {
      mouseX = -9999;
      mouseY = -9999;
    }

    function start() {
      resize();
      rafId = requestAnimationFrame(draw);
    }

    function stop() {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = null;
    }

    // Pause Animation wenn Hero nicht im Viewport
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) start();
        else stop();
      });
    }, { threshold: 0.01 });

    observer.observe(canvas);

    // Resize-Handling
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(resize, 200);
    });

    // Mouse-Tracking
    canvas.parentElement?.addEventListener('mousemove', onMouseMove);
    canvas.parentElement?.addEventListener('mouseleave', onMouseLeave);

    // Initial start
    start();
  })();
</script>
