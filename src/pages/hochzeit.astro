---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import { getCollection } from 'astro:content';
import seitentexte from '../data/seiten/hochzeit.json';

const title = 'Hochzeit feiern im Bürgerhaus Mittelberg — Pakete & Ablauf';
const description = 'Hochzeitspakete im Bürgerhaus Mittelberg: Standesamt im Stüble, Hochzeit im Festsaal, Komplett-Tag. Transparente Preise, eigene Küche, persönliche Betreuung.';

const pakete = (await getCollection('pakete')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
const faqs = (await getCollection('faq')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);

const slugMap: Record<string, string> = {
  'Standesamt im Stüble': 'standesamt',
  'Hochzeit im Festsaal': 'festsaal',
  'Komplett-Hochzeit': 'komplett',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.data.frage,
    acceptedAnswer: { '@type': 'Answer', text: f.data.antwort.trim() },
  })),
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <BreadcrumbSchema items={[{ name: 'Hochzeit', url: '/hochzeit' }]} />
  </Fragment>

  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">Hochzeit</span>
      <h1>{seitentexte.titel}</h1>
      <p class="lead mx-auto">{seitentexte.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {pakete.map((p, index) => {
        const slug = slugMap[p.data.titel] || `paket-${p.data.reihenfolge}`;
        return (
          <div class={`package${p.data.highlight ? ' package--highlight' : ''}`} id={slug}>
            <header class="package__head">
              <h2>Paket {index + 1} — {p.data.titel}</h2>
              <p class="package__sub">{p.data.untertitel}</p>
            </header>
            <div class="package__body grid grid-2">
              <div>
                <h4>Im Preis enthalten</h4>
                <ul class="bullets">
                  {p.data.enthalten.map((e) => <li>{e.punkt}</li>)}
                </ul>
              </div>
              <div>
                <h4>Nicht enthalten</h4>
                <ul class="bullets bullets--minus">
                  {p.data.nicht_enthalten.map((e) => <li>{e.punkt}</li>)}
                </ul>
                <p class="package__price">
                  ab <strong>{p.data.preis} €</strong> pro Person<br/>
                  <small>min. {p.data.min_personen} Personen</small>
                </p>
                <a
                  href={`/anfragen?paket=${slug}`}
                  class={`btn ${p.data.highlight ? 'btn--primary' : 'btn--secondary'} btn--arrow`}
                >{p.data.titel} anfragen</a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Optional dazubuchbar -->
  <section class="section section--cream-warm">
    <div class="container">
      <span class="eyebrow">Zusätzlich</span>
      <h2>Optional dazubuchbar</h2>
      <table class="specs">
        <tbody>
          <tr><th>Hochzeitstorte (über unsere Konditorei-Partnerin)</th><td>ab 6,50 € pro Stück</td></tr>
          <tr><th>Mitternachtssnack (Burger, Käsespätzle, Suppe)</th><td>14 € pro Person</td></tr>
          <tr><th>Brunch am Folgetag</th><td>28 € pro Person</td></tr>
          <tr><th>Erweiterte Tonanlage / Lichttechnik</th><td>auf Anfrage</td></tr>
          <tr><th>DJ-Empfehlung über uns</th><td>DJ rechnet direkt mit euch ab</td></tr>
          <tr><th>Floristik-Empfehlung</th><td>Floristin rechnet direkt mit euch ab</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Tagesablauf -->
  <section class="section" id="tagesablauf">
    <div class="container--narrow">
      <span class="eyebrow">Tagesablauf</span>
      <h2>Wie eine Hochzeit bei uns aussieht</h2>

      <div class="timeline">
        <div class="timeline__item">
          <span class="timeline__marker">Vormittag</span>
          <p>Ihr kommt mit den Trauzeugen, wir bereiten gemeinsam das Stüble vor. Familie und Gäste treffen ein.</p>
        </div>
        <div class="timeline__item">
          <span class="timeline__marker">Mittag</span>
          <p>Standesamtliche oder freie Trauung im Stüble oder Festsaal. Sektempfang im Anschluss.</p>
        </div>
        <div class="timeline__item">
          <span class="timeline__marker">Nachmittag</span>
          <p>Kaffee und Kuchen, Fotos vor dem Haus, Spaziergang im Ort.</p>
        </div>
        <div class="timeline__item">
          <span class="timeline__marker">Abend</span>
          <p>Festessen, Reden, Tanzen. Eure Live-Band, euer DJ — die Bühne ist eure.</p>
        </div>
        <div class="timeline__item">
          <span class="timeline__marker">Nacht</span>
          <p>Bar, Tanzfläche, Mitternachtssnack. Wir bleiben so lange ihr bleibt — bis 3 Uhr.</p>
        </div>
        <div class="timeline__item">
          <span class="timeline__marker">Folgetag</span>
          <p>Optional: Brunch im Stüble für alle, die geblieben sind.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ aus Backend -->
  <section class="section section--cream-warm" id="faq">
    <div class="container--narrow">
      <span class="eyebrow">Häufige Fragen</span>
      <h2>FAQ Hochzeit</h2>

      {faqs.map((f) => (
        <details class="faq">
          <summary>{f.data.frage}</summary>
          <p>{f.data.antwort}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">Sprecht mit uns</h2>
      <p class="lead mx-auto">
        Schickt uns euer Wunschdatum und eure Fragen. Wir antworten innerhalb von 48 Stunden.
      </p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">Anfrage stellen</a>
    </div>
  </section>
</BaseLayout>

<style>
  .package {
    background: var(--c-cream);
    border: 1px solid var(--c-line);
    padding: var(--s-7);
    margin-bottom: var(--s-6);
  }
  .package--highlight {
    border: 2px solid var(--c-brass);
    box-shadow: var(--shadow-md);
  }
  .package__head { margin-bottom: var(--s-5); }
  .package__sub { color: var(--c-mid); font-size: var(--t-md); margin-top: -1rem; }
  .package__body { gap: var(--s-7); }
  .package__price {
    font-family: var(--f-display);
    font-size: var(--t-md);
    border-top: 1px solid var(--c-line);
    padding-top: var(--s-3);
    margin: var(--s-4) 0;
  }
  .package__price strong { font-size: var(--t-2xl); color: var(--c-blue); }
  .package__price small { color: var(--c-mid); font-size: var(--t-sm); font-family: var(--f-body); }

  .timeline { display: flex; flex-direction: column; gap: var(--s-5); margin-top: var(--s-6); }
  .timeline__item {
    display: grid; grid-template-columns: 8rem 1fr; gap: var(--s-5); align-items: start;
    padding: var(--s-4) 0;
    border-top: 1px solid var(--c-line);
  }
  .timeline__item:first-child { border-top: 0; padding-top: 0; }
  .timeline__marker {
    font-family: var(--f-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--c-blue); font-size: var(--t-sm);
  }
  @media (max-width: 600px) {
    .timeline__item { grid-template-columns: 1fr; gap: var(--s-2); }
  }

  .faq {
    border-bottom: 1px solid var(--c-line);
    padding: var(--s-4) 0;
  }
  .faq summary {
    font-family: var(--f-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    font-size: var(--t-md); cursor: pointer; padding-right: var(--s-5);
    list-style: none; position: relative;
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after {
    content: '+'; position: absolute; right: 0; top: 0;
    font-size: var(--t-xl); line-height: 1; color: var(--c-blue);
    transition: transform var(--transition);
  }
  .faq[open] summary::after { content: '−'; }
  .faq p { margin-top: var(--s-3); color: var(--c-mid); white-space: pre-line; }
</style>
