---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import { getCollection } from 'astro:content';
import seitentexte from '../data/seiten/hochzeit.json';

const title = 'Hochzeit feiern im Bürgerhaus Mittelberg — Festsaal & Service';
const description = 'Hochzeitsfeier im Bürgerhaus Mittelberg: Festsaal für 50 bis 250 Gäste, eigene Küche, Sektempfang, Service, Tanzfläche, bis 3 Uhr ohne Aufpreis. Allgäu, gutbürgerlich.';

const faqs = (await getCollection('faq')).sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.data.frage,
    acceptedAnswer: { '@type': 'Answer', text: f.data.antwort.trim() },
  })),
};

const enthalten = [
  'Festsaal exklusiv für Sie und Ihre Gäste',
  'Mehr-Gänge-Menü aus unserer Küche, gutbürgerlich und regional',
  'Sektempfang vor dem Haus oder im Saal',
  'Service-Personal über die gesamte Veranstaltung',
  'Tanzfläche, Bühne und Bar',
  'Mitternachtssnack: Käse- oder Wurstplatte',
  'Getränke nach Verbrauch — keine Pauschalen',
  'Reinigung im Anschluss',
  'Feier bis 3 Uhr morgens — ohne Aufpreis',
];

const selbst = [
  'Musik (DJ oder Band) — gerne empfehlen wir Ihnen jemanden',
  'Hochzeitstorte — auf Wunsch über unsere Konditorei-Partnerin',
  'Floristik und Tischschmuck',
  'Fotograf',
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <BreadcrumbSchema items={[{ name: 'Hochzeit', url: '/hochzeit' }]} />
  </Fragment>

  <section class="section--hero">
    <div class="container--narrow text-center">
      <span class="eyebrow">Hochzeit</span>
      <h1>{seitentexte.titel}</h1>
      <p class="lead mx-auto">{seitentexte.lead}</p>
    </div>
  </section>

  <!-- Hauptbereich: Was wir bieten -->
  <section class="section" id="leistungen">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Hochzeitsfeier im Festsaal</span>
        <h2 class="text-balance">Alles aus einer Hand</h2>
        <p class="lead mx-auto">
          Von 50 bis 250 Gästen, vom Sektempfang bis zur durchgetanzten Nacht. Wir kümmern uns um Saal, Küche und Service — Sie und Ihre Gäste feiern.
        </p>
      </div>

      <div class="leistungs-grid">
        <div class="leistungs-block leistungs-block--enthalten">
          <h3>
            <span class="leistungs-block__icon" aria-hidden="true">✓</span>
            Was wir leisten
          </h3>
          <ul class="leistungs-list">
            {enthalten.map((punkt) => <li>{punkt}</li>)}
          </ul>
        </div>

        <div class="leistungs-block leistungs-block--selbst">
          <h3>
            <span class="leistungs-block__icon" aria-hidden="true">→</span>
            Was Sie selbst mitbringen
          </h3>
          <ul class="leistungs-list">
            {selbst.map((punkt) => <li>{punkt}</li>)}
          </ul>
          <p class="leistungs-block__note">
            Auf Wunsch geben wir Ihnen Empfehlungen für Musik, Floristik und Konditorei aus unserem Allgäuer Netzwerk.
          </p>
        </div>
      </div>

      <div class="leistungs-cta">
        <p class="leistungs-cta__price">Preis auf Anfrage</p>
        <p class="leistungs-cta__desc">
          Jede Hochzeit ist anders — Gästezahl, Menü und Wünsche bestimmen den Preis.
          Wir machen Ihnen gerne ein konkretes Angebot nach einem persönlichen Vorgespräch.
        </p>
        <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg">Termin anfragen</a>
      </div>
    </div>
  </section>

  <!-- Tagesablauf — als Phasen, nicht Uhrzeiten -->
  <section class="section section--cream-warm" id="tagesablauf">
    <div class="container--narrow">
      <span class="eyebrow">Tagesablauf</span>
      <h2>Wie eine Hochzeit bei uns abläuft</h2>
      <p class="lead">
        Ein klassischer Ablauf — alternative Wünsche besprechen wir gerne im Vorgespräch.
      </p>

      <div class="ablauf">
        <div class="ablauf__item">
          <span class="ablauf__marker">1</span>
          <div>
            <h4>Tag vorher</h4>
            <p>
              Falls keine andere Veranstaltung im Haus ist, können Sie bereits am Vortag dekorieren und aufbauen.
              So beginnt der Hochzeitstag entspannt.
            </p>
          </div>
        </div>

        <div class="ablauf__item">
          <span class="ablauf__marker">2</span>
          <div>
            <h4>Vormittag — Hochzeitskuchen</h4>
            <p>
              Sie können Ihren eigenen Hochzeitskuchen am Vormittag bei uns vorbeibringen.
              Wir kümmern uns um die Aufbewahrung bis zum Servieren.
            </p>
          </div>
        </div>

        <div class="ablauf__item">
          <span class="ablauf__marker">3</span>
          <div>
            <h4>Sektempfang nach der Trauung</h4>
            <p>
              Nach der Trauung in Standesamt oder Kirche kommen Sie und Ihre Gäste zu uns.
              Sektempfang vor dem Haus — bei schlechtem Wetter im Saal.
            </p>
          </div>
        </div>

        <div class="ablauf__item">
          <span class="ablauf__marker">4</span>
          <div>
            <h4>Kaffee & Kuchen</h4>
            <p>
              Vom Buffet, in entspannter Runde. Zeit für Fotos, Begrüßungen und ein erstes Durchatmen.
            </p>
          </div>
        </div>

        <div class="ablauf__item">
          <span class="ablauf__marker">5</span>
          <div>
            <h4>Brautstehlen — wenn Sie mögen</h4>
            <p>
              Der Allgäuer Brauch darf bei einer Hochzeit nicht fehlen. Im nahegelegenen Partystadel
              werden Wein und Brot von uns gestellt.
              Alternativ gibt es zwei weitere Wirtschaften in Mittelberg, die das Brautstehlen ebenfalls ausrichten.
            </p>
          </div>
        </div>

        <div class="ablauf__item">
          <span class="ablauf__marker">6</span>
          <div>
            <h4>Abendessen im Festsaal</h4>
            <p>
              Mehr-Gänge-Menü aus unserer Küche — gutbürgerlich, regional und auf Wunsch zusammengestellt.
              Auf Allergien, vegetarische und vegane Gäste gehen wir gerne ein.
            </p>
          </div>
        </div>

        <div class="ablauf__item">
          <span class="ablauf__marker">7</span>
          <div>
            <h4>Feier bis in die Nacht</h4>
            <p>
              Tanzfläche, Bühne, Bar. Mitternachtssnack mit Käse- oder Wurstplatte.
              Die Feier geht bis 3 Uhr morgens — ohne Aufpreis.
            </p>
          </div>
        </div>
      </div>

      <p class="ablauf__hinweis">
        Sie wünschen einen anderen Ablauf? Sagen Sie uns, was Sie sich vorstellen — wir richten uns nach Ihnen.
      </p>
    </div>
  </section>

  <!-- FAQ aus Backend -->
  <section class="section" id="faq">
    <div class="container--narrow">
      <span class="eyebrow">Häufige Fragen</span>
      <h2>FAQ Hochzeit</h2>

      {faqs.map((f) => (
        <details class="faq">
          <summary>{f.data.frage}</summary>
          <p>{f.data.antwort}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="section section--blue">
    <div class="container--narrow text-center">
      <h2 class="text-balance">Sprechen Sie mit uns</h2>
      <p class="lead mx-auto">
        Schreiben Sie uns Ihr Wunschdatum, die Gästezahl und Ihre Fragen. Wir antworten innerhalb von 48 Stunden mit einem konkreten Vorschlag.
      </p>
      <a href="/anfragen" class="btn btn--primary btn--arrow btn--lg mt-6">Anfrage stellen</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Info-Card mit Mokka-Akzent */
  .info-card {
    border-left: 3px solid var(--c-mokka);
    background: var(--c-cream-warm);
    padding: var(--s-5) var(--s-6);
    border-radius: 0 var(--r-md) var(--r-md) 0;
  }
  .info-card__eyebrow {
    font-family: var(--f-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: var(--t-xs);
    color: var(--c-mokka);
    margin: 0 0 var(--s-2);
  }
  .info-card__text {
    margin: 0;
    color: var(--c-anthracite);
    line-height: 1.6;
  }

  /* Leistungs-Grid */
  .leistungs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-5);
    margin-bottom: var(--s-7);
  }
  @media (min-width: 800px) {
    .leistungs-grid { grid-template-columns: 1.2fr 1fr; gap: var(--s-6); }
  }

  .leistungs-block {
    background: var(--c-cream);
    border: 1px solid var(--c-line);
    border-radius: var(--r-md);
    padding: var(--s-6);
  }
  .leistungs-block--enthalten {
    border: 2px solid var(--c-mokka);
    background: var(--c-cream-warm);
  }
  .leistungs-block h3 {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin: 0 0 var(--s-5);
    font-size: var(--t-xl);
  }
  .leistungs-block__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--c-mokka);
    color: var(--c-cream);
    font-weight: 700;
    flex-shrink: 0;
  }
  .leistungs-block--selbst .leistungs-block__icon {
    background: transparent;
    border: 2px solid var(--c-line);
    color: var(--c-mid);
  }
  .leistungs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .leistungs-list li {
    padding-left: var(--s-5);
    position: relative;
    line-height: 1.5;
  }
  .leistungs-block--enthalten .leistungs-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--c-mokka);
    font-weight: 700;
  }
  .leistungs-block--selbst .leistungs-list li::before {
    content: '·';
    position: absolute;
    left: var(--s-2);
    color: var(--c-mid);
    font-weight: 700;
    font-size: 1.5em;
    line-height: 1;
  }
  .leistungs-block__note {
    margin-top: var(--s-5);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-line);
    font-size: var(--t-sm);
    color: var(--c-mid);
    line-height: 1.5;
  }

  /* CTA-Bereich */
  .leistungs-cta {
    text-align: center;
    padding: var(--s-7) var(--s-5);
    background: var(--c-cream-warm);
    border-radius: var(--r-md);
  }
  .leistungs-cta__price {
    font-family: var(--f-display);
    font-size: var(--t-3xl);
    color: var(--c-blue);
    margin: 0 0 var(--s-3);
    font-weight: 500;
    letter-spacing: -0.02em;
  }
  .leistungs-cta__desc {
    color: var(--c-anthracite);
    margin: 0 auto var(--s-5);
    max-width: 38rem;
    line-height: 1.6;
  }

  /* Ablauf — Phasen statt Timeline */
  .ablauf {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    margin-top: var(--s-6);
  }
  .ablauf__item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--s-5);
    align-items: start;
  }
  .ablauf__marker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--c-mokka);
    color: var(--c-cream);
    font-family: var(--f-display);
    font-size: var(--t-lg);
    font-weight: 500;
    flex-shrink: 0;
  }
  .ablauf__item h4 {
    margin: 0 0 var(--s-2);
    font-size: var(--t-lg);
    color: var(--c-anthracite);
  }
  .ablauf__item p {
    margin: 0;
    color: var(--c-mid);
    line-height: 1.6;
  }
  .ablauf__hinweis {
    margin-top: var(--s-7);
    padding: var(--s-4) var(--s-5);
    background: var(--c-cream);
    border-left: 3px solid var(--c-blue);
    font-style: italic;
    color: var(--c-anthracite);
  }
  @media (max-width: 600px) {
    .ablauf__item { grid-template-columns: 2rem 1fr; gap: var(--s-3); }
    .ablauf__marker { width: 2rem; height: 2rem; font-size: var(--t-md); }
  }

  /* FAQ — bestehende Styles */
  .faq {
    border-bottom: 1px solid var(--c-line);
    padding: var(--s-4) 0;
  }
  .faq summary {
    font-family: var(--f-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    font-size: var(--t-md); cursor: pointer; padding-right: var(--s-5);
    list-style: none; position: relative;
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after {
    content: '+'; position: absolute; right: 0; top: 0;
    font-size: var(--t-xl); line-height: 1; color: var(--c-blue);
    transition: transform var(--transition);
  }
  .faq[open] summary::after { content: '−'; }
  .faq p { margin-top: var(--s-3); color: var(--c-mid); white-space: pre-line; }
</style>
