---
import kontakt from '../data/kontakt.json';
const year = new Date().getFullYear();
const tel = kontakt.telefon.replace(/\s/g, '').replace(/^0/, '');
---

<footer class="footer">
  <div class="container--wide">
    <div class="footer__grid">
      <div class="footer__col">
        <p class="footer__brand">{kontakt.name}</p>
        <p>{kontakt.strasse}<br/>{kontakt.ort}<br/>Allgäu, Bayern</p>
      </div>

      <div class="footer__col">
        <p class="footer__head">Kontakt</p>
        <p>
          <a href={`tel:+49${tel}`}>{kontakt.telefon}</a><br/>
          <a href={`mailto:${kontakt.email}`}>{kontakt.email}</a>
        </p>
      </div>

      <div class="footer__col">
        <p class="footer__head">Folgen</p>
        <ul class="footer__social">
          {kontakt.instagram && <li><a href={kontakt.instagram} rel="noopener" target="_blank">Instagram</a></li>}
          {kontakt.facebook && <li><a href={kontakt.facebook} rel="noopener" target="_blank">Facebook</a></li>}
        </ul>
      </div>

      <div class="footer__col">
        <p class="footer__head">Anfrage</p>
        <a href="/anfragen" class="btn btn--ghost btn--arrow">Termin anfragen</a>
      </div>
    </div>

    <div class="footer__legal">
      <p>© {year} {kontakt.name}</p>
      <ul>
        <li><a href="/ueber-uns">Über uns</a></li>
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="/datenschutz">Datenschutz</a></li>
        <li><button type="button" data-cookie-settings>Cookie-Einstellungen</button></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-blue-deep);
    color: var(--c-cream);
    padding: var(--s-9) 0 var(--s-5);
    margin-top: var(--s-9);
  }
  .footer a { color: var(--c-cream); }
  .footer a:hover { color: var(--c-brass-light); }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-7);
    padding: 0 var(--s-5);
    margin-bottom: var(--s-8);
  }
  @media (max-width: 800px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: var(--s-5); }
  }
  @media (max-width: 480px) {
    .footer__grid { grid-template-columns: 1fr; }
  }

  .footer__col { font-size: var(--t-sm); }
  .footer__brand {
    font-family: var(--f-body); font-weight: 600; text-transform: uppercase;
    font-size: var(--t-md); letter-spacing: 0.06em;
    margin-bottom: var(--s-3);
  }
  .footer__head {
    font-family: var(--f-body); font-weight: 600; text-transform: uppercase;
    font-size: var(--t-sm); letter-spacing: 0.18em;
    margin-bottom: var(--s-3);
    color: var(--c-brass-light);
  }
  .footer__social { display: flex; flex-direction: column; gap: var(--s-1); }

  .footer__legal {
    border-top: 1px solid rgba(250, 246, 238, 0.15);
    padding: var(--s-5);
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: var(--s-4);
    font-size: var(--t-sm);
  }
  .footer__legal ul { display: flex; gap: var(--s-5); flex-wrap: wrap; }
  .footer__legal button {
    color: var(--c-cream); cursor: pointer;
    font-size: inherit; padding: 0;
    text-decoration: underline; text-decoration-color: rgba(250, 246, 238, 0.4);
  }
  .footer__legal button:hover { color: var(--c-brass-light); }
</style>
