# Bürgerhaus Mittelberg — Netlify Headers

# Sicherheits-Header (Best Practice für SEO + Browser-Vertrauen)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Statische Assets aggressiv cachen (1 Jahr, immutable)
/logo.svg
  Cache-Control: public, max-age=31536000, immutable

/logo.png
  Cache-Control: public, max-age=31536000, immutable

/logo-square.png
  Cache-Control: public, max-age=31536000, immutable

/og-default.jpg
  Cache-Control: public, max-age=31536000, immutable

/videos/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# CSS und Fonts: lange Cache-Zeit, da Astro Hashes nutzt
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# HTML-Seiten: kurze Cache + Revalidierung
/*.html
  Cache-Control: public, max-age=0, must-revalidate
